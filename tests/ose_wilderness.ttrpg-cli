// OSE wilderness travel integration tests
//
// Equivalent of the runtime tests in
// crates/ttrpg_interp/tests/ose_wilderness_integration.rs
// Tests terrain property derives and wilderness mechanics with scripted dice.
//
// AST structure tests remain in Rust.

load ose/*.ttrpg

// ── Terrain property derives ───────────────────────────────────

assert_eq terrain_move_cost_num(WtForest), 3
assert_eq terrain_move_cost_den(WtForest), 2

assert_eq terrain_move_cost_num(WtMountains), 3
assert_eq terrain_move_cost_den(WtMountains), 1

assert_eq terrain_lost_chance(WtJungle), 2
assert_eq terrain_lost_chance(WtClear), 1

assert_eq terrain_encounter_chance(WtOcean), 2
assert_eq terrain_encounter_chance(WtCity), 1

assert_eq terrain_forage_chance(WtRiver), 2
assert_eq terrain_forage_chance(WtBarren), 0

assert_eq terrain_can_forage(WtForest), true
assert_eq terrain_can_forage(WtCity), false

// ── Starvation penalty ─────────────────────────────────────────

assert_eq starvation_penalty(-3), 0
assert_eq starvation_penalty(0), 0
assert_eq starvation_penalty(1), -1
assert_eq starvation_penalty(3), -3
assert_eq starvation_penalty(7), -4

// ── Lost checks ────────────────────────────────────────────────

// Forest lost chance is 2-in-6.
rolls clear
rolls 2
assert_eq terrain_lost_check(WtForest), true

rolls clear
rolls 3
assert_eq terrain_lost_check(WtForest), false

// ── Encounter checks ───────────────────────────────────────────

// Clear encounter chance is 1-in-6.
rolls clear
rolls 1
assert_eq terrain_encounter_check(WtClear), true

rolls clear
rolls 3
assert_eq terrain_encounter_check(WtClear), false

// ── Forage checks ──────────────────────────────────────────────

// River forage chance is 2-in-6.
rolls clear
rolls 1
assert_eq terrain_forage_check(WtRiver), true

rolls clear
rolls 4
assert_eq terrain_forage_check(WtRiver), false

// Barren forage chance is 0-in-6, so even the lowest roll fails.
rolls clear
rolls 1
assert_eq terrain_forage_check(WtBarren), false

// ── Orient checks ──────────────────────────────────────────────

// Mountains lost chance is 1, so orient chance is 5-in-6.
rolls clear
rolls 5
assert_eq terrain_orient_check(WtMountains), true

rolls clear
rolls 6
assert_eq terrain_orient_check(WtMountains), false

// Jungle lost chance is 2, so orient chance is 4-in-6.
rolls clear
rolls 4
assert_eq terrain_orient_check(WtJungle), true

rolls clear
rolls 5
assert_eq terrain_orient_check(WtJungle), false
