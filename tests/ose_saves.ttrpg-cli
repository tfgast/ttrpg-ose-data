// OSE Saving Throws integration tests
//
// Equivalent of the runtime tests in
// crates/ttrpg_interp/tests/ose_saves_integration.rs
// Tests convenience derives (get_save_*) across classes, levels, and tiers.
//
// AST structure tests remain in Rust.

load ose/*.ttrpg

// ── Fighter saves at level 1 ────────────────────────────────────

assert_eq get_save_death(Fighter, 1), 12
assert_eq get_save_wands(Fighter, 1), 13
assert_eq get_save_paralysis(Fighter, 1), 14
assert_eq get_save_breath(Fighter, 1), 15
assert_eq get_save_spells(Fighter, 1), 16

// ── Fighter saves at level 7 (tier boundary) ────────────────────

assert_eq get_save_death(Fighter, 7), 8
assert_eq get_save_wands(Fighter, 7), 9
assert_eq get_save_paralysis(Fighter, 7), 10
assert_eq get_save_breath(Fighter, 7), 10
assert_eq get_save_spells(Fighter, 7), 12

// ── Magic-User saves at level 11 ────────────────────────────────

assert_eq get_save_death(MagicUser, 11), 8
assert_eq get_save_spells(MagicUser, 11), 8
assert_eq get_save_breath(MagicUser, 11), 11

// ── Dwarf saves at level 10 (demihuman high tier) ───────────────

assert_eq get_save_death(Dwarf, 10), 2
assert_eq get_save_wands(Dwarf, 10), 3
assert_eq get_save_paralysis(Dwarf, 10), 4
assert_eq get_save_breath(Dwarf, 10), 4
assert_eq get_save_spells(Dwarf, 10), 6

// ── Thief saves tier transitions ────────────────────────────────

// Level 4 (tier 1): death=13
assert_eq get_save_death(Thief, 4), 13

// Level 5 (tier 2): death=12
assert_eq get_save_death(Thief, 5), 12

// ── Out-of-range level errors ───────────────────────────────────

// Elf max level is 10, level 11 should produce a no-match error
assert_err call get_save_death(Elf, 11)
