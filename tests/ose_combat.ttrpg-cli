// OSE Combat & Morale integration tests
//
// Equivalent of the runtime tests in
// crates/ttrpg_interp/tests/ose_combat_integration.rs
// Tests target_number, calc_ac, missile_range_mod, phase_sequence,
// phase_actor_order, skip_phase, monster_thac0, reaction_outcome,
// attack_roll, morale_check, reaction_roll, should_check_morale.
//
// AST structure tests remain in Rust.

load ose/*.ttrpg

// ── target_number ───────────────────────────────────────────────

// THAC0 19 vs AC 9 = need 10
assert_eq target_number(19, 9), 10

// THAC0 19 vs AC 5 = need 14
assert_eq target_number(19, 5), 14

// THAC0 19 vs AC -3 = need 22
assert_eq target_number(19, -3), 22

// ── calc_ac ─────────────────────────────────────────────────────

// AC 9 (unarmoured), no shield, DEX mod 0
assert_eq calc_ac(9, 0, 0), 9

// Chain mail AC 5, shield (1), DEX mod +1 → 5 - 1 - 1 = 3
assert_eq calc_ac(5, 1, 1), 3

// Leather AC 7, no shield, DEX mod -1 → 7 - 0 - (-1) = 8
assert_eq calc_ac(7, 0, -1), 8

// ── missile_range_mod ───────────────────────────────────────────

// Short bow: 50/100/150, distance 30 → +1
assert_eq missile_range_mod(30, 50, 100, 150), 1

// Exactly at short range boundary → +1
assert_eq missile_range_mod(50, 50, 100, 150), 1

// Medium range → 0
assert_eq missile_range_mod(75, 50, 100, 150), 0

// Long range → -1
assert_eq missile_range_mod(120, 50, 100, 150), -1

// Beyond long range → error
assert_err call missile_range_mod(151, 50, 100, 150)

// ── phase_sequence ──────────────────────────────────────────────

assert_eq phase_sequence(), [CombatPhase.Declaration, CombatPhase.Initiative, CombatPhase.Morale, CombatPhase.Movement, CombatPhase.Missile, CombatPhase.Magic, CombatPhase.Melee, CombatPhase.EndOfRound]

// ── phase_actor_order ───────────────────────────────────────────

assert_eq phase_actor_order(CombatPhase.Declaration, InitiativeWinner.Party), [PhaseActorSlot.Both]
assert_eq phase_actor_order(CombatPhase.Melee, InitiativeWinner.Party), [PhaseActorSlot.Party, PhaseActorSlot.Monsters]

// ── skip_phase ──────────────────────────────────────────────────

assert_eq skip_phase(CombatPhase.Magic, false, true), true

// ── monster_thac0 table ─────────────────────────────────────────

assert_eq monster_thac0(0), 20
assert_eq monster_thac0(1), 19
assert_eq monster_thac0(3), 19
assert_eq monster_thac0(4), 17
assert_eq monster_thac0(6), 17
assert_eq monster_thac0(7), 14
assert_eq monster_thac0(9), 14
assert_eq monster_thac0(10), 12
assert_eq monster_thac0(12), 12
assert_eq monster_thac0(13), 10
assert_eq monster_thac0(15), 10
assert_eq monster_thac0(16), 8
assert_eq monster_thac0(18), 8
assert_eq monster_thac0(19), 6
assert_eq monster_thac0(25), 6

// ── reaction_outcome table ──────────────────────────────────────

assert_eq reaction_outcome(2), Hostile
assert_eq reaction_outcome(3), Unfriendly
assert_eq reaction_outcome(5), Unfriendly
assert_eq reaction_outcome(6), ReactionOutcome.Neutral
assert_eq reaction_outcome(8), ReactionOutcome.Neutral
assert_eq reaction_outcome(9), Indifferent
assert_eq reaction_outcome(11), Indifferent
assert_eq reaction_outcome(12), Friendly

// ── attack_roll mechanic ────────────────────────────────────────

// Natural 1 always misses (even with huge bonuses)
rolls 1
assert_eq attack_roll(19, 9, 10), AttackOutcome.Miss

// Natural 20 always hits (even with huge penalties)
rolls 20
assert_eq attack_roll(19, -10, -5), AttackOutcome.Hit

// Standard hit: THAC0 19 vs AC 5 → target 14. Roll 14 + mod 0 = 14, hits.
rolls 14
assert_eq attack_roll(19, 5, 0), AttackOutcome.Hit

// Standard miss: Roll 13 + mod 0 = 13 < 14
rolls 13
assert_eq attack_roll(19, 5, 0), AttackOutcome.Miss

// With STR modifier: Roll 12 + mod 2 = 14, hits.
rolls 12
assert_eq attack_roll(19, 5, 2), AttackOutcome.Hit

// ── morale_check mechanic ───────────────────────────────────────

// Morale 7, roll 6 → 6 <= 7 → hold
rolls 3 3
assert_eq morale_check(7), MoraleOutcome.Hold

// Morale 7, roll 9 → 9 > 7 → fail
rolls 5 4
assert_eq morale_check(7), MoraleOutcome.Fail

// Morale 7, roll 7 → 7 <= 7 → hold (equal = hold)
rolls 4 3
assert_eq morale_check(7), MoraleOutcome.Hold

// ── reaction_roll mechanic ──────────────────────────────────────

// Roll 7, CHA mod 0 → 7 → neutral
rolls 4 3
assert_eq reaction_roll(0), ReactionOutcome.Neutral

// Roll 8, CHA mod +2 → 10 → indifferent
rolls 5 3
assert_eq reaction_roll(2), ReactionOutcome.Indifferent

// Roll 3, CHA mod -3 → 0 → clamped to 2 → hostile
rolls 2 1
assert_eq reaction_roll(-3), ReactionOutcome.Hostile

// Roll 11, CHA mod +3 → 14 → clamped to 12 → friendly
rolls 6 5
assert_eq reaction_roll(3), ReactionOutcome.Friendly

// ── should_check_morale ─────────────────────────────────────────

// First death, not yet checked → should trigger
assert_eq should_check_morale(1, 5, false, false), true

// First death, already checked → should not trigger
assert_eq should_check_morale(1, 5, true, false), false

// Half killed, not yet checked → should trigger
assert_eq should_check_morale(3, 5, true, false), true
